{
  "id": "vscode-js-debug-installer",
  "name": "vscode-js-debug",
  "check": {
    "fileExists": {
      "name": "Check if vscode-js-debug is installed",
      "file": "$SERVER_HOME$/src/dapDebugServer.js"
    }
  },
  "run": {
    "download": {
      "name": "Download vscode-js-debug",
      "github": {
        "owner": "microsoft",
        "repository": "vscode-js-debug",
        "prerelease": false,
        "asset": "js-debug-dap-*.tar.gz"
      },
      "url": "https://github.com/microsoft/vscode-js-debug/releases/download/v1.100.1/js-debug-dap-v1.100.1.tar.gz",
      "output": {
        "dir": "$SERVER_HOME$"
      },
      "onSuccess": {
        "configureServer": {
          "name": "Configure vscode-js-debug command",
          "command": "node ${output.dir}/src/dapDebugServer.js",
          "update": true
        }
      }
    }
  }
}
