{
	"id": "microprofile",
	"name": "MicroProfile Language Server",
	"check": {
		"fileExists": {
			"name": "Check if MicroProfile is installed",
			"file": "$SERVER_HOME$/org.eclipse.lsp4mp.ls-uber.jar"
		}
	},
	"run": {
		"copy": {
			"name": "Copy MicroProfile LS JAR",
			"source": "/lsp/microprofile/lib/org.eclipse.lsp4mp.ls-uber.jar",
			"destination": "$SERVER_HOME$/org.eclipse.lsp4mp.ls-uber.jar",
			"onSuccess": {
				"configureServer": {
					"name": "Configure MicroProfile server command",
					"command": "java -jar \"$SERVER_HOME$/org.eclipse.lsp4mp.ls-uber.jar\"",
					"update": true
				}
			}
		}
	}
}